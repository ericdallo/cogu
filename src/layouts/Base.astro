---
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import CartDrawer from "@components/react/CartDrawer";
import { Image } from "astro:assets";
import catImage from "@assets/details/cat.png";
import "@/styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Cogu — Serviço de entregas aconchegantes",
  description = "Pequenas coisas também são mágicas. Cadernos, adesivos e papelaria artesanal feitos com carinho.",
} = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>{title}</title>

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-0KF5VNRQWK"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-0KF5VNRQWK');
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <main class="flex-1 relative overflow-hidden">
      <!-- Decorative cats -->
      <Image src={catImage} alt="" width={140} height={140}
        class="absolute right-24 top-[30%] opacity-[0.18] rotate-12 pointer-events-none select-none hidden md:block z-0" />
      <Image src={catImage} alt="" width={120} height={120}
        class="absolute left-20 top-[55%] opacity-[0.16] -rotate-6 -scale-x-100 pointer-events-none select-none hidden md:block z-0" />
      <Image src={catImage} alt="" width={150} height={150}
        class="absolute right-32 top-[75%] opacity-[0.14] -rotate-12 pointer-events-none select-none hidden md:block z-0" />
      <Image src={catImage} alt="" width={110} height={110}
        class="absolute left-28 top-[90%] opacity-[0.17] rotate-6 -scale-x-100 pointer-events-none select-none hidden md:block z-0" />
      <slot />
    </main>
    <Footer />
    <CartDrawer client:load />
  </body>
</html>
