---
import { Image } from "astro:assets";
import heroImage from "@assets/products/mini-fichario/product-1.png";
import { url } from "@/utils/paths";
---

<section class="relative h-[85vh] md:h-[90vh] overflow-hidden">
  <!-- Full-bleed background image -->
  <Image
    src={heroImage}
    alt="Mini Fichário Cogu — fichário artesanal feito à mão"
    width={1600}
    height={2133}
    quality={90}
    class="absolute inset-0 w-full h-full object-cover object-[center_85%]"
  />

  <!-- Dark overlay for text readability -->
  <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/20 to-transparent"></div>

  <!-- Text content anchored to bottom -->
  <div class="absolute inset-0 flex flex-col justify-end">
    <div class="container-cogu pb-14 md:pb-20 space-y-5">
      <h1 class="text-cogu-cream leading-tight">
        Pequenas coisas<br />
        também são <span class="text-cogu-yellow">mágicas</span>.
      </h1>
      <p class="text-cogu-cream/80 text-lg md:text-xl max-w-lg leading-relaxed">
        Cadernos, adesivos e papelaria artesanal feitos à mão para tornar cada
        rotina mais leve, mais bonita, mais sua.
      </p>
      <div class="flex gap-4 pt-2">
        <a
          href={url("/produtos")}
          class="bg-cogu-cream text-cogu-green px-6 py-3 rounded-full font-sans font-medium hover:bg-cogu-yellow transition-colors duration-300 inline-flex items-center gap-2 no-underline"
        >
          Ver produtos
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </a>
        <a
          href={url("/sobre")}
          class="border-2 border-cogu-cream/80 text-cogu-cream px-6 py-3 rounded-full font-sans font-medium hover:bg-cogu-cream/10 transition-colors duration-300 no-underline"
        >
          Nossa história
        </a>
      </div>
    </div>
  </div>
</section>
