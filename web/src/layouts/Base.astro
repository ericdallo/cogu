---
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import CartDrawer from "@components/react/CartDrawer";

import "@/styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Cogu — Serviço de entregas aconchegantes",
  description = "Pequenas coisas também são mágicas. Cadernos, adesivos e papelaria artesanal feitos com carinho.",
} = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>{title}</title>

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-0KF5VNRQWK"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-0KF5VNRQWK');
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <CartDrawer client:load />
  </body>
</html>
