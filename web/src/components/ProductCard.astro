---
import { Image } from "astro:assets";
import type { Product } from "@data/products";
import { formatPrice } from "@data/products";
import { url } from "@/utils/paths";

interface Props {
  product: Product;
}

const { product } = Astro.props;

const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/products/**/*.png"
);

const resolvedImages = product.images
  .map((img) => images[`/src/assets/products/${img}`])
  .filter(Boolean);
---

<a
  href={url(`/produtos/${product.slug}`)}
  class="group block no-underline hover:no-underline"
>
  <article class="space-y-4">
    <!-- Image carousel -->
    <div class="relative overflow-hidden rounded-2xl bg-cogu-sage/20 aspect-[3/4]" data-carousel>
      {
        resolvedImages.map((mod, i) => (
          <Image
            src={mod()}
            alt={product.name}
            width={900}
            height={1200}
            quality={85}
            class:list={[
              "absolute inset-0 object-cover w-full h-full transition-opacity duration-1000 ease-in-out group-hover:scale-105 transition-all",
              i === 0 ? "opacity-100" : "opacity-0",
            ]}
            data-slide={i}
          />
        ))
      }

      {/* One badge per slide, fades with its image */}
      {
        product.badges && product.badges.map((badge, i) => (
          i < resolvedImages.length && (
            <span
              class:list={[
                "absolute top-3 right-3 px-2.5 py-1 text-[10px] font-sans font-semibold rounded-full shadow-lg backdrop-blur-sm transition-opacity duration-1000 ease-in-out z-10",
                i === 0 ? "opacity-100" : "opacity-0",
                i === 0
                  ? "bg-cogu-red/90 text-cogu-cream"
                  : i === 1
                    ? "bg-cogu-green/90 text-cogu-cream"
                    : "bg-cogu-cream/95 text-cogu-brown border border-cogu-brown/15",
              ]}
              data-badge={i}
            >
              {badge}
            </span>
          )
        ))
      }
    </div>

    <!-- Info -->
    <div class="space-y-1 px-1">
      <p class="text-cogu-brown/50 text-xs uppercase tracking-wider">
        {product.category}
      </p>
      <h3 class="text-cogu-green text-lg font-display group-hover:text-cogu-brown transition-colors">
        {product.name}
      </h3>
      <p class="text-cogu-brown/70 text-sm line-clamp-2">
        {product.description}
      </p>
      <p class="text-cogu-green font-medium pt-1">
        {formatPrice(product.price)}
      </p>
    </div>
  </article>
</a>

<script>
  document.querySelectorAll<HTMLElement>("[data-carousel]").forEach((carousel) => {
    const slides = carousel.querySelectorAll<HTMLElement>("[data-slide]");
    const badges = carousel.querySelectorAll<HTMLElement>("[data-badge]");
    if (slides.length <= 1) return;

    let current = 0;
    setInterval(() => {
      slides[current].classList.replace("opacity-100", "opacity-0");
      badges[current]?.classList.replace("opacity-100", "opacity-0");
      current = (current + 1) % slides.length;
      slides[current].classList.replace("opacity-0", "opacity-100");
      badges[current]?.classList.replace("opacity-0", "opacity-100");
    }, 3500);
  });
</script>
