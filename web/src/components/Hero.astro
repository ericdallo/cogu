---
import { Image } from "astro:assets";
import heroImage from "@assets/hero.jpeg";
import { url } from "@/utils/paths";
---

<section class="relative h-[85vh] md:h-[90vh] overflow-hidden">
  <!-- Full-bleed background image -->
  <Image
    src={heroImage}
    alt="Cogu — Serviço de entregas aconchegantes"
    width={1080}
    height={1440}
    quality={90}
    class="absolute inset-0 w-full h-[120%] object-cover object-[center_95%] will-change-transform"
    id="hero-img"
  />

  <!-- Dark overlay for text readability -->
  <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/20 to-transparent"></div>

  <!-- Text content anchored to bottom -->
  <div class="absolute inset-0 flex flex-col justify-end">
    <div class="container-cogu pb-14 md:pb-20 space-y-5">
      <h1 class="text-cogu-cream leading-tight">
        Pequenas coisas<br />
        também são <span class="text-cogu-cream italic">mágicas</span>.
      </h1>
      <p class="text-cogu-cream/80 text-lg md:text-xl max-w-lg leading-relaxed">
        Papelaria e coisinhas para o seu dia a dia
      </p>
      <div class="flex gap-4 pt-2">
        <a
          href={url("/produtos")}
          class="bg-cogu-cream text-cogu-brown px-6 py-3 rounded-xl font-sans font-medium hover:bg-cogu-sage transition-colors duration-300 inline-flex items-center gap-2 no-underline"
        >
          Ver produtos
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </a>

      </div>
    </div>
  </div>
</section>

<script>
  const img = document.getElementById("hero-img") as HTMLImageElement;
  const section = img?.closest("section");

  if (img && section && window.matchMedia("(prefers-reduced-motion: no-preference)").matches) {
    let ticking = false;
    window.addEventListener("scroll", () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          const rect = section.getBoundingClientRect();
          if (rect.bottom > 0) {
            const offset = window.scrollY * 0.3;
            img.style.transform = `translateY(${offset}px)`;
          }
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });
  }
</script>
