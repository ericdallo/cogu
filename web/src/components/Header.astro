---
import { Image } from "astro:assets";
import logo from "@assets/logo.png";
import { url } from "@/utils/paths";
---

<header class="sticky top-0 z-40 bg-cogu-cream/95 backdrop-blur-sm border-b border-cogu-sage/30">
  <div class="container-cogu flex items-center justify-between h-16 md:h-20">
    <!-- Logo -->
    <a href={url("/")} class="no-underline hover:no-underline flex items-center gap-2">
      <Image
        src={logo}
        alt="Cogu"
        width={120}
        height={120}
        quality={90}
        class="rounded-full w-10 h-10"
      />
      <span class="font-title font-bold text-cogu-green text-xl md:text-2xl">cogu</span>
    </a>

    <!-- Navigation -->
    <nav class="hidden md:flex items-center gap-8">
      <a
        href={url("/produtos")}
        class="text-cogu-brown no-underline hover:text-cogu-green transition-colors text-sm uppercase tracking-wider font-medium"
      >
        Produtos
      </a>
      <a
        href={url("/sobre")}
        class="text-cogu-brown no-underline hover:text-cogu-green transition-colors text-sm uppercase tracking-wider font-medium"
      >
        Sobre a COGU
      </a>
    </nav>

    <!-- Mobile menu -->
    <div class="flex items-center gap-4">
      <!-- Mobile menu button -->
      <button
        id="mobile-menu-toggle"
        class="md:hidden p-2 text-cogu-brown hover:text-cogu-green transition-colors"
        aria-label="Menu"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile navigation -->
  <nav
    id="mobile-menu"
    class="md:hidden hidden border-t border-cogu-sage/30 bg-cogu-cream"
  >
    <div class="container-cogu py-4 flex flex-col gap-4">
      <a
        href={url("/produtos")}
        class="text-cogu-brown no-underline hover:text-cogu-green transition-colors text-sm uppercase tracking-wider font-medium"
      >
        Produtos
      </a>
      <a
        href={url("/sobre")}
        class="text-cogu-brown no-underline hover:text-cogu-green transition-colors text-sm uppercase tracking-wider font-medium"
      >
        Sobre a COGU
      </a>
    </div>
  </nav>
</header>

<script>
  const mobileToggle = document.getElementById("mobile-menu-toggle");
  const mobileMenu = document.getElementById("mobile-menu");

  mobileToggle?.addEventListener("click", () => {
    mobileMenu?.classList.toggle("hidden");
  });
</script>
