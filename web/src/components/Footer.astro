---
import { Image } from "astro:assets";
import catImage from "@assets/details/cat.png";
import { url } from "@/utils/paths";
const currentYear = new Date().getFullYear();
---

<footer class="relative bg-cogu-green text-cogu-cream mt-20 overflow-hidden">
  <Image
    src={catImage}
    alt=""
    width={140}
    height={140}
    class="absolute right-6 md:right-12 top-8 opacity-20 rotate-12 pointer-events-none select-none"
  />
  <div class="container-cogu py-12 md:py-16 relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
      <!-- Brand -->
      <div class="space-y-4">
        <h3 class="font-display text-cogu-cream text-2xl">cogu</h3>
        <p class="text-cogu-sage text-sm leading-relaxed max-w-xs">
          Serviço de entregas aconchegantes.<br />
          Pequenas coisas também são mágicas.
        </p>
      </div>

      <!-- Links -->
      <div class="space-y-4">
        <h4 class="text-cogu-cream text-sm uppercase tracking-wider font-medium">
          Navegue
        </h4>
        <nav class="flex flex-col gap-2">
          <a
            href={url("/produtos")}
            class="text-cogu-sage no-underline hover:text-cogu-cream transition-colors text-sm"
          >
            Produtos
          </a>
          <a
            href={url("/sobre")}
            class="text-cogu-sage no-underline hover:text-cogu-cream transition-colors text-sm"
          >
            Sobre a Cogu
          </a>
        </nav>
      </div>

      <!-- Social -->
      <div class="space-y-4">
        <h4 class="text-cogu-cream text-sm uppercase tracking-wider font-medium">
          Acompanhe
        </h4>
        <a
          href="https://instagram.com/cogupaper"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-cogu-sage no-underline hover:text-cogu-cream transition-colors text-sm"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
            <path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"></path>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
          </svg>
          @cogupaper
        </a>
      </div>
    </div>

    <div
      class="border-t border-cogu-cream/20 mt-10 pt-6 text-center text-cogu-sage text-xs"
    >
      © {currentYear} Cogu. Feito com carinho 🍄
    </div>
  </div>
</footer>
