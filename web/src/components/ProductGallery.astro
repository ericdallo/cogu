---
import { Image } from "astro:assets";

interface Props {
  productImages: string[];
  productName: string;
  badges?: string[];
}

const { productImages, productName, badges = [] } = Astro.props;

const allImages = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/products/**/*.png"
);

const resolvedImages = productImages
  .map((img) => {
    const path = `/src/assets/products/${img}`;
    return allImages[path] ? { path, loader: allImages[path] } : null;
  })
  .filter(Boolean) as { path: string; loader: () => Promise<{ default: ImageMetadata }> }[];
---

<div class="space-y-4">
  <!-- Main image -->
  {
    resolvedImages.length > 0 && (
      <div class="relative overflow-hidden rounded-2xl bg-cogu-sage/20 aspect-[3/4]">
        <Image
          src={resolvedImages[0].loader()}
          alt={productName}
          width={1050}
          height={1400}
          quality={90}
          id="gallery-main"
          class="object-cover w-full h-full"
        />

        {/* One badge per image, only first visible */}
        {badges.map((badge, i) => (
          <span
            class:list={[
              "gallery-badge absolute top-4 left-4 px-3 py-1.5 text-xs font-sans font-semibold rounded-full shadow-lg backdrop-blur-sm transition-opacity duration-300",
              i === 0 ? "opacity-100" : "opacity-0 pointer-events-none",
              i === 0
                ? "bg-cogu-red/90 text-cogu-cream"
                : i === 1
                  ? "bg-cogu-green/90 text-cogu-cream"
                  : "bg-cogu-cream/95 text-cogu-brown border border-cogu-brown/15",
            ]}
            data-badge-index={i}
          >
            {badge}
          </span>
        ))}
      </div>
    )
  }

  <!-- Thumbnails -->
  {
    resolvedImages.length > 1 && (
      <div class="grid grid-cols-4 gap-3">
        {resolvedImages.map((img, i) => (
          <button
            class:list={[
              "overflow-hidden rounded-xl bg-cogu-sage/20 aspect-[3/4] border-2 transition-colors gallery-thumb",
              i === 0 ? "border-cogu-green" : "border-transparent hover:border-cogu-sage",
            ]}
            data-index={i}
          >
            <Image
              src={img.loader()}
              alt={`${productName} - foto ${i + 1}`}
              width={250}
              height={333}
              quality={80}
              class="object-cover w-full h-full"
            />
          </button>
        ))}
      </div>
    )
  }
</div>

<script>
  const thumbs = document.querySelectorAll(".gallery-thumb");
  const mainImg = document.getElementById("gallery-main") as HTMLImageElement;
  const badges = document.querySelectorAll<HTMLElement>(".gallery-badge");

  thumbs.forEach((thumb) => {
    thumb.addEventListener("click", () => {
      const img = thumb.querySelector("img");
      const index = Number(thumb.getAttribute("data-index"));

      if (img && mainImg) {
        mainImg.src = img.src;
        mainImg.alt = img.alt;

        // Update thumbnail borders
        thumbs.forEach((t) => {
          t.classList.remove("border-cogu-green");
          t.classList.add("border-transparent");
        });
        thumb.classList.remove("border-transparent");
        thumb.classList.add("border-cogu-green");

        // Swap badge
        badges.forEach((badge) => {
          const badgeIndex = Number(badge.getAttribute("data-badge-index"));
          if (badgeIndex === index) {
            badge.classList.remove("opacity-0", "pointer-events-none");
            badge.classList.add("opacity-100");
          } else {
            badge.classList.remove("opacity-100");
            badge.classList.add("opacity-0", "pointer-events-none");
          }
        });
      }
    });
  });
</script>
